mimPublish(trailer ,"Std Cust Count",long);
mimPublish(trailer ,"Pre Cust Count",long);
int stdCount,perCount;
beginBatch{
   stdCount = 0;
   perCount = 0;
}
consume {
    debug(input);
    //Typecast input
    EventUsg ip = (EventUsg)input;
    //Create output format
    EventUsgOut op = udrCreate(EventUsgOut);
    op.eventId = ip.eventId;
    //op.normalizedMsisdn = "+91-"+ip.msisdn;
    op.normalizedMsisdn = strInsert(ip.msisdn, 0, "+91-");
    
    op.normalizedEmail = strToLower(strTrim(ip.subscriberEmail));
    //op.normalizedEmail = strToLower(op.normalizedEmail);
    //john.doe@example.com
    /*
    int idx = strIndexOf(op.normalizedEmail, "@");
    op.emailDomain = strSubstring(op.normalizedEmail,idx+1,strLength(op.normalizedEmail));
    */
    list<string> liEmail = strSplit(op.normalizedEmail,"@");
    op.emailDomain = listGet(liEmail,1);
    //debug("liEmail:"+liEmail);
    
    op.customerCategory = strToLower(strTrim(ip.customerSegment));
    op.serviceCircle = strToUpper(ip.circle);
    
    list<string> liRechPlan = strSplit(ip.rechargePlan,"-");
    op.planCategory = listGet(liRechPlan,1);
    op.planExpiryYear = listGet(liRechPlan,2);
    
    list<string> liRechDetails = strSplit(ip.rechargeDetails,":");
    op.rechargeAmount = listGet(liRechDetails,1);
    op.transactionStatus = listGet(liRechDetails,2);
    /*
    if(op.planCategory == "GOLD" || op.planCategory == "PLATINUM"){
        op.customerTier = "PREMIUM";    
    }else{
        op.customerTier = "STANDARD"; 
    }
    */
    op.customerTier = (op.planCategory == "GOLD" || op.planCategory == "PLATINUM") ?"PREMIUM" : "STANDARD";
    /*
    if(strEndsWith(op.normalizedEmail,".com") == true){
        op.isCorporateEmail = true;    
    }else{
        op.isCorporateEmail = false;  
    }*/
    op.isCorporateEmail = strEndsWith(op.normalizedEmail,".com") ? true : false;
    op.isValidMsisdn = strREMatches(ip.msisdn,"^[0-9]{10}$")? true : false;
    op.billingProfileKey = ip.msisdn +"_"+op.planCategory+"_"+op.serviceCircle;
    //debug(op);
   
    if(op.customerTier == "PREMIUM"){
        perCount++;
        udrRoute(op,"pre");
    }else{
        stdCount++;
        udrRoute(op,"std");
    }
    
}
endBatch{
    mimSet("Std Cust Count",stdCount);
    mimSet("Pre Cust Count",perCount);
