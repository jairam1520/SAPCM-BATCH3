CCCycleUDR createChargeReq(ParcelRatingRequest parcel){
    CCCycleUDR  ccCycle = udrCreate(CCCycleUDR);
    ChargeUDR charge = udrCreate(ChargeUDR);
    ccCycle.request = charge;
    date consDate;
    strToDate(consDate,parcel.consumptionDate,"yyyy-MM-dd");
    charge.consumptionDate = consDate;
    charge.userId = parcel.userIdentifier;
    if(parcel.zzservType == "Domestic"){
        charge.chargeableItemName = "ZDEX";
        charge.serviceId = "DEX"; 
    }
    charge.ciPropertyList = listCreate(PropertyUDR);
    listAdd(charge.ciPropertyList,createPropertyUDR("ZZWEIGHT",parcel.zzweight));
    listAdd(charge.ciPropertyList,createPropertyUDR("ZZHEIGHT",parcel.zzheight));
    listAdd(charge.ciPropertyList,createPropertyUDR("ZZLENGTH",parcel.zzlength));
    listAdd(charge.ciPropertyList,createPropertyUDR("ZZWIDTH",parcel.zzwidth));
    listAdd(charge.ciPropertyList,createPropertyUDR("ZZZONE",parcel.zzzone));
    listAdd(charge.ciPropertyList,createPropertyUDR("ZZSERV_TYPE",parcel.zzservType));    
    
    ChargeExecutionContextUDR chargeContext = udrCreate(ChargeExecutionContextUDR);
    chargeContext.outputChargeableItemExported = false;
    chargeContext.resultNotificationReturned = true;
    chargeContext.resultChargingContractInfoReturned = true;
    /*chargeContext.resultAccountInfoReturned = false;
    chargeContext.resultAccountOperationReturned = false;
    chargeContext.resultAllReturned = false;
    chargeContext.resultChargeableItemInfoReturned = false;
    chargeContext.resultChargedItemReturned = false;
    chargeContext.resultChargingContractInfoReturned = false;
    chargeContext.resultChargingProcessInfoReturned = false;
    chargeContext.resultResponseItemReturned = false;*/
    charge.chargeExecutionContext = chargeContext;
    
    return ccCycle;
                
}
PropertyUDR createPropertyUDR(string name,any value){
   PropertyUDR udr = udrCreate(PropertyUDR);
   udr.name = name;
   udr.value = value;
   return udr; 
}
void mapNotifToResp(ChargingResultUDR result,ParcelRatingResponse parcelResp){
    for(NotificationUDR notifUdr : result.notifications){
        for(NotificationArgumentUDR notif:notifUdr.notifArgList) {
            if(notif.name == "computed.PARCEL_AMOUNT"){
               strToDouble(parcelResp.parcelTotalAmount, (string)notif.value);
            }else if(notif.name == "computed.VOLUMETRIC_WEIGHT"){
               strToDouble(parcelResp.volumetricWeight, (string)notif.value);
            }
        }  
    }
}

boolean isValidParcelReq(ParcelRatingRequest parcel) {
    // 1. Check for null object reference
    if (parcel == null) {
        return false;
    }
    
    // 2. Validate Default Properties (Presence checks)
    if (parcel.consumptionDate == null) {
        return false;
    }
    if (parcel.userIdentifier == null || parcel.userIdentifier == "") {
        return false;
    }
    if (parcel.serviceIdentifier == null || parcel.serviceIdentifier == "") {
        return false;
    }
    
    // 3. Validate User Properties (Physical attributes must be strictly greater than 0)
    if (parcel.zzweight <= 0) {
        return false;
    }
    if (parcel.zzlength <= 0) {
        return false;
    }
    if (parcel.zzwidth <= 0) {
        return false;
    }
    if (parcel.zzheight <= 0) {
        return false;
    }
    
    // 4. Validate Routing/Classification Fields (Presence checks)
    if (parcel.zzzone == null || parcel.zzzone == "") {
        return false;
    }
    if (parcel.zzservType == null || parcel.zzservType  == "") {
        return false;
    }
    
    // All validation checks passed successfully
    return true;
}]]></string>
