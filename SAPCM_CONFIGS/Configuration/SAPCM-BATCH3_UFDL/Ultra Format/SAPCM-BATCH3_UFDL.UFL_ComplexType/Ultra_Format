<exportmultiplex category="Ultra_Format" ref_path="ultra_format[Internal]/storable[ultra_format]/storable[Data]">
   <string name="Definition"><![CDATA[/*
Decoder to decode complex types
*/

/*
 Record structure:
 BP01,110,20-08-2025,20-09-2025,MH|Mumbai|400702#f1;f2
*/

external ElecUsageExt{
    ascii bp : terminated_by(",");  
    ascii usage : terminated_by(",");
    ascii startDate : terminated_by(",");
    ascii endDate : terminated_by(",");  
    AddressExt address;
};

external AddressExt{
    ascii stateCode : terminated_by("|");  
    ascii city : terminated_by("|");
    ascii zipCode : terminated_by("#");
    MyTypeExt myType;
};
external MyTypeExt{
    ascii f1 : terminated_by(";");    
    ascii f2 : terminated_by(0x0A);    
};
/*internal ElecUsageInt{
    string bp;
    string usage;
    string startDate;
    string endDate;
    AddressInt address;    
};
*/
internal AddressInt{
   string stateCode;
   string city;
   int zipCode; 
   MyTypeInt myType; 
};

in_map m_Inmap : external(MyTypeExt),target_internal(MyTypeInt){automatic;};
in_map a_Inmap : external(AddressExt),internal(AddressInt){
    automatic{
        MyTypeExt :  using in_map m_Inmap;   
    };};
in_map e_Inmap : external(ElecUsageExt),target_internal(ElecUsageTI){
    automatic{
        AddressExt : using in_map a_Inmap;
    };
};

decoder elecDec : in_map(e_Inmap);

]]></string>
</exportmultiplex>
