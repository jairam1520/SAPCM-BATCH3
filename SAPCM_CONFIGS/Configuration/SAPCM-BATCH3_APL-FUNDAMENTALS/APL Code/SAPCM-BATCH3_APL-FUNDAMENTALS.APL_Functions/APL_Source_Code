   <string name="Definition"><![CDATA[import ultra.SAPCM-BATCH3_APL-FUNDAMENTALS.UFL_USAGE;


//check if the UsageInt record is valid or not
boolean isUsageRecValid(UsageInt usage){
    if(usage.callType != null && usage.callType != "" 
    && usage.cellId != null && usage.cellId != ""
    && usage.duration != null && usage.duration != ""
    && usage.eventTime != null && usage.eventTime != ""
    && usage.msisdn != null && usage.msisdn != ""
    
    ){
       //valid record
       
        return true; 
    }else{
        return false;    
    }
    
}

//populates event type from UsageInt to UsageOut
void populateEventType(UsageOut usgOut,UsageInt usage){
    /*
    VOICE --> VOICE_CALL
    SMS --> SMS
    DATA --> DATA_SESSION
    */
    /*if(usage.eventType == "VOICE"){
        usgOut.serviceType = "VOICE_CALL";
    }else if(usage.eventType == "SMS"){
        usgOut.serviceType = "SMS";
    }else if(usage.eventType == "DATA"){
        usgOut.serviceType = "DATA_SESSION";
    }   */  
    
    switch(usage.eventType){
        case "VOICE"  {
            usgOut.serviceType = "VOICE_CALL";    
        } 
        case "SMS"  {
            usgOut.serviceType = "SMS";    
        } 
        case "DATA"  {
            usgOut.serviceType = "DATA_SESSION";    
        } 
    }
}

