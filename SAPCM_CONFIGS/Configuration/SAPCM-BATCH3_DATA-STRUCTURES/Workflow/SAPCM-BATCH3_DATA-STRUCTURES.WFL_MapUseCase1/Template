map<string,UsageRecord> mpAggRec;
beginBatch{
   //sessions = listCreate(string);  
   mpAggRec = mapCreate(string,UsageRecord);  
}
consume {
    if(mapContains(mpAggRec,input.msisdn)){
        //msisdn exist in map, do agregation
        UsageRecord existingUsage = mapGet(mpAggRec,input.msisdn);  
        existingUsage.consumedMB = existingUsage.consumedMB + input.consumedMB;
    }else{
        mapSet(mpAggRec,input.msisdn,input);    
    }
}
drain{
    for(UsageRecord rec : mapValues(mpAggRec)){
        udrRoute(rec);    
    }
}]]></string>
